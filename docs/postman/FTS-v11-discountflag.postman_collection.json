        "body": {
          "mode": "raw",
          "raw": "{\n  \"ORGTIN\": \"{{org_tin}}\",\n  \"APIKEY\": \"{{apikey}}\",\n  \"VERSION\": \"{{version}}\",\n  \"ERPUSER\": \"{{erp_user}}\",\n  \"VOUCHERTYPE\": \"Sales\",\n  \"VOUCHERTYPENAME\": \"Sales Invoice\",\n  \"VOUCHERNUMBER\": \"INV-DF-{{ts}}\",\n  \"VOUCHERREF\": \"INV-REF-{{ts}}\",\n  \"INDUSTRYCODE\": \"101\",\n  \"CURRENCY\": \"UGX\",\n  \"BUYERTIN\": \"{{buyer_tin}}\",\n  \"BUYERNINBRN\": \"\",\n  \"BUYERPASSPORTNUM\": \"\",\n  \"BUYERLEGALNAME\": \"POSTMAN BUYER\",\n  \"BUSINESSNAME\": \"POSTMAN BUYER\",\n  \"BUYERADDRESS\": \"Kampala\",\n  \"MOBILEPHONE\": \"0700000000\",\n  \"BUYERLINEPHONE\": \"\",\n  \"BUYEREMAIL\": \"buyer@example.com\",\n  \"BUYERPLACEOFBUSI\": \"Kampala\",\n  \"BUYERTYPE\": \"1\",\n  \"BUYERCITIZENSHIP\": \"1\",\n  \"BUYERSECTOR\": \"1\",\n  \"BUYERREFERENCENO\": \"\",\n  \"REMARKS\": \"Postman discount flag invoice test\",\n  \"NONRESIDENTFLAG\": \"0\",\n  \"PROJECTID\": \"\",\n  \"PROJECTNAME\": \"\",\n  \"DELIVERYTERMCODE\": \"101\",\n  \"PRICEVATINCLUSIVE\": \"YES\",\n  \"WINDOWSUSER\": \"{{windows_user}}\",\n  \"IPADDRESS\": \"{{ip_address}}\",\n  \"MACADDRESS\": \"{{mac_address}}\",\n  \"SYSTEMNAME\": \"{{system_name}}\",\n  \"INVENTORIES\": [\n    {\n      \"PRODUCTCODE\": \"{{product_code}}\",\n      \"QTY\": \"1\",\n      \"RATE\": \"100000\",\n      \"AMOUNT\": \"100000\",\n      \"TAXRATE\": \"0.18\",\n      \"DISCOUNTPCT\": \"10\",\n      \"DISCOUNT\": \"10000\",\n      \"DISCOUNTFLAG\": \"1\"\n    }\n  ],\n  \"PAYMENTS\": [\n    {\n      \"PAYMENTMODE\": \"101\",\n      \"AMOUNT\": \"90000\"\n    }\n  ]\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('responseCode exists', function () {",
              "  const data = pm.response.json();",
              "  pm.expect(data.response.responseCode).to.exist;",
              "});"
            ]
          }
        }
      ]
